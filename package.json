{
  "type": "module",
  "scripts": {
    "dev": "nodemon --ignore public/geoip --ignore public/configs --ignore tmp server.js",
    "start": "node server.js",
    "worker": "node worker.js",
    "update:geoip": "node scripts/updateGeoip.js",
    "test:geoip": "node --test tests/geoip.integration.test.js",
    "upload:r2": "node scripts/uploadGeoipToR2.js",
  "deploy:geoip": "npm run update:geoip && npm run upload:r2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-cron": "^4.5.0",
    "tar": "^7.5.16"
  }
}
